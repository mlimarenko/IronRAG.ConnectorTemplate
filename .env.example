# --- IronRAG endpoint ---
# Base URL of the IronRAG backend (e.g. http://127.0.0.1:9464 for a local
# stack or https://graph.example.com for a hosted one). The connector calls
# /v1/content/documents/* endpoints under this base.
IRONRAG_BASE_URL=http://127.0.0.1:9464

# API token with POLICY_DOCUMENTS_WRITE on every library this connector can
# target via routing.yaml. Treat as a secret.
IRONRAG_API_TOKEN=irt_xxxxxxxxxxxx

# --- Routing ---
# Path to YAML file mapping source items to (workspace, library) pairs.
# See routing.yaml.example for the canonical schema.
ROUTING_CONFIG_PATH=routing.yaml

# --- Run mode ---
# How the connector picks up source changes:
#   poll     : only the periodic sweep runs; any registered webhook
#              handlers are ignored on mount.
#   webhook  : only webhook handlers are mounted; the periodic sweep is
#              disabled. Manual POST /sync/run still works as catch-up.
#   both     : sweep + webhooks side by side. Sweep acts as the
#              reconciliation safety net for missed webhook deliveries.
RUN_MODE=both

# --- Sync loop (consulted unless RUN_MODE=webhook) ---
# Seconds between full sweeps. Minimum 60.
SYNC_INTERVAL_SECONDS=1800
# Run a full sweep on startup before the periodic loop begins.
SYNC_RUN_ON_STARTUP=false
# Max concurrent items in flight per sweep.
SYNC_CONCURRENCY=4

# --- Push policies ---
# Defaults apply to every kind unless overridden in routing.yaml under
# `policies: { <kind>: { ... } }`.
# on_new       : create | skip
# on_changed   : replace | skip
# on_missing   : delete | ignore
# on_duplicate_content : skip | fail
DEFAULT_POLICY_ON_NEW=create
DEFAULT_POLICY_ON_CHANGED=replace
DEFAULT_POLICY_ON_MISSING=delete
DEFAULT_POLICY_ON_DUPLICATE_CONTENT=skip

# --- Persistent state ---
# SQLite database used to remember which source items were already pushed.
# Survives restart so the next sweep ships only the diff.
STATE_DB_PATH=./connector-state.sqlite

# --- HTTP server ---
HOST=0.0.0.0
PORT=8088
LOG_LEVEL=info

# Static bearer token required on /sync/run and /webhook/* admin endpoints.
ADMIN_BEARER_TOKEN=change-me

# Optional path for the single-instance pidfile lock. Defaults to a name
# derived from the connector under /tmp.
# PIDFILE_PATH=/tmp/my-connector.pid

# HTTP request timeout in seconds against IronRAG.
REQUEST_TIMEOUT_SECONDS=60
